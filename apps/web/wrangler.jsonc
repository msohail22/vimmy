{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "web",
	"main": "worker/index.ts",
	"compatibility_date": "2026-05-14",
	"assets": {
		"not_found_handling": "single-page-application"
	},
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"compatibility_flags": [
		"nodejs_compat"
	],
	"env": {
		"dev": {
			"name": "vimmy-web"
		}
	}
}
